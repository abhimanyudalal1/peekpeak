{
    "manifest_version": 3,
    "name": "AI Quick Explain",
    "version": "1.0",
    "description": "Highlight text to get a quick AI explanation.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "AI Quick Explain"
    },
    "options_ui": {
        "page": "settings.html",
        "open_in_tab": true
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ]
        }
    ],
    "commands": {
        "explain-selection": {
            "suggested_key": {
                "default": "Alt+A",
                "mac": "Alt+A"
            },
            "description": "Explain selected text briefly"
        }
    }
}